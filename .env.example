# LM Studio (local) — no API key needed
LLM_API_BASE=http://host.docker.internal:1234/v1
LLM_API_KEY=lm-studio
LLM_COGNITIVE_MODEL=lmstudio-community/gemma-3-12b-it-GGUF
LLM_EXTRACTION_MODEL=lmstudio-community/gemma-3-12b-it-GGUF
LLM_UTILITY_MODEL=lmstudio-community/gemma-3-12b-it-GGUF

# Embeddings — LM Studio embedding model
EMBEDDING_API_BASE=http://host.docker.internal:1234/v1
EMBEDDING_API_KEY=lm-studio
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
EMBEDDING_DIMENSIONS=768

# Database (overridden by docker-compose for containers)
DATABASE_URL=postgresql+asyncpg://eidolon_agent_memory:eidolon_agent_memory@localhost:25433/eidolon_agent_memory

# MCP server
MCP_TRANSPORT=http
MCP_PORT=3100

# Optional: server secret for signing API keys
API_KEY_SECRET=change-me-in-production
